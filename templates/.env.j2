# ─────────────────────────────────────────────────────────────────────────────
# Haiggle — Application Environment Template
# Rendered per school by Ansible provision.yml
# DO NOT commit real secrets — all sensitive values come from Ansible vault.
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME="Haiggle"
APP_ENV={{ app_env | default('production') }}
APP_KEY={{ app_key }}
APP_DEBUG=false
APP_URL=https://{{ school_domain }}
APP_TIMEZONE=America/Port-au-Prince

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ── Database ──────────────────────────────────────────────────────────────────
# Laravel connects to PgBouncer (transaction mode) on port 6432
DB_CONNECTION=pgsql
DB_HOST=pgbouncer
DB_PORT=6432
DB_DATABASE={{ db_name }}
DB_USERNAME=haiggle
DB_PASSWORD={{ db_password }}

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD={{ redis_password }}

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log

# ── MinIO (S3-compatible object storage) ─────────────────────────────────────
FILESYSTEM_DISK=minio
AWS_ACCESS_KEY_ID={{ minio_root_user }}
AWS_SECRET_ACCESS_KEY={{ minio_root_password }}
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=haiggle-storage
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

BACKUP_DISK=backups
AWS_BUCKET_BACKUPS=haiggle-backups

# ── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER={{ mail_mailer | default('smtp') }}
MAIL_HOST={{ mail_host }}
MAIL_PORT={{ mail_port | default(587) }}
MAIL_USERNAME={{ mail_username }}
MAIL_PASSWORD={{ mail_password }}
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="{{ mail_from_address | default('noreply@haiggle.com') }}"
MAIL_FROM_NAME="${APP_NAME}"

# ── HMP Management ────────────────────────────────────────────────────────────
HMP_MANAGEMENT_TOKEN={{ hmp_management_token }}
HMP_API_URL={{ hmp_api_url }}

# ── Sanctum / CORS ────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS={{ school_domain }},localhost
SESSION_DOMAIN=.{{ school_domain }}
SESSION_SECURE_COOKIE=true

# ── Subscription / Tenant ────────────────────────────────────────────────────
APP_PLAN={{ app_plan | default('base') }}
APP_SUSPENDED=false
APP_RESTRICTED=false

# ── Import limits ─────────────────────────────────────────────────────────────
IMPORT_MAX_ROWS=5000
IMPORT_DISK=local

# ── Student cap (set 0 for unlimited) ────────────────────────────────────────
APP_MAX_ACTIVE_STUDENTS={{ max_active_students | default(0) }}

# ── Sentry error monitoring ───────────────────────────────────────────────────
SENTRY_LARAVEL_DSN={{ sentry_dsn | default('') }}

# ── Training mode (set true on training instances only) ──────────────────────
APP_TRAINING={{ is_training | default(false) | lower }}
